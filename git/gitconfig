[core]
  editor = vim
  eol = lf
  autocrlf = input
  safecrlf = true
  attributesfile = ~/.gitattributes

[color]
  ui = auto

[log]
  date = format-local:"%Y-%m-%d %H:%M:%S"

[pretty]
  compact = format:"%C(green)[%h]%C(reset) %<(72,trunc)%s %C(cyan)%>(12,ltrunc)%(trailers:valueonly)%-%C(reset) %C(yellow)[%ad]%C(reset) [%G?] %C(bold red)%an%C(reset) %C(blue)%d%C(reset)"

[gpg]
  program = gpg

[init]
  defaultbranch = master

[commit]
  gpgsign = true
  template = ~/.gitmessage

[tag]
  gpgsign = true

[pull]
  ff = only

[push]
  autosetupremote = true

[alias]
  unstage = reset

[trailer]
  separators = ":#"

[advice]
  addEmptyPathspec = false

[include]
  path = ~/.gitconfig.user
